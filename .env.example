# --- Obligatorias (sin ellas el servidor no arranca) ---
# Runtime SQLite-only: una URL única para todos los módulos (auth/users/ads/favorites/complaints).
SQLITE_DATABASE_URL=./data/venta_libre.db

# Puerto y host de escucha (PORT obligatorio; HOST opcional, por defecto 0.0.0.0)
PORT=3000
HOST=0.0.0.0

# Orígenes CORS permitidos (coma; el backend hace trim por entrada). Deben coincidir exactamente con el header Origin del navegador.
# Dev dual: miniserve/Makefile suele servir en :8080; Live Server suele usar :3000 (127.0.0.1 y localhost son orígenes distintos para CORS).
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:3000,http://localhost:3000

# JWT (obligatorio; no uses el valor de ejemplo en producción)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION_HOURS=24
JWT_ADMIN_EXPIRATION_HOURS=168

# Timeout global de request (segundos)
REQUEST_TIMEOUT_SECS=30

# --- Opcionales ---
# development | production
# ENVIRONMENT=development

# URL pública de documentación; si está vacía, el JSON de GET / no incluye la clave "docs"
# PUBLIC_DOCS_URL=https://github.com/tu-org/venta-libre
